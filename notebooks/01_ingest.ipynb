    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"../data/houses.csv\")\n",
    "# convert types\n",
    "df[\"MSZoning\"] = df[\"MSZoning\"].astype(\"category\")\n",
    "df[\"Neighborhood\"] = df[\"Neighborhood\"].astype(\"category\")\n",
    "\n",
    "df.to_parquet(\"../data/houses.parquet\")\n",
    "\n",
    "print(df.shape)"
   ]
